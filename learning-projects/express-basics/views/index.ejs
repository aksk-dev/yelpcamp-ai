<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Comments</title>
</head>
<body>
    <h1>Comments</h1>
    <ul>
        <% comments.forEach(function(comment) { %>
            <li>
                <strong><%= comment.username %>:</strong> <%= comment.comment %>
                <!-- Details link -->
                <a href="/comments/<%= comment.id %>">Details</a>
            </li>
        <% }); %>
    </ul>
</body>
</html>
